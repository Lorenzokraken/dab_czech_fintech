    "CATALOG = \"czech_fintech\"\n",
    "SILVER = \"silver\"\n",
    "tables = [\"transactions\", \"account\", \"client\", \"card\", \"disp\", \"district\", \"loan\", \"order\"]\n",
    "for t in tables:\n",
    "    spark.sql(f\"DROP TABLE IF EXISTS {CATALOG}.{SILVER}.{t}\")\n",
    "print(\"✅ Silver tables dropped\")"
   ]
